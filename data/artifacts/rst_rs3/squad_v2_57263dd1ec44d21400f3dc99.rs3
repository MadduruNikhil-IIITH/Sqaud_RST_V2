	<body>
		<segment id="1" parent="21" relname="organization">On 16 March 2012,</segment>
		<segment id="2" parent="14" relname="span">52 Greenpeace activists from five different countries boarded Fennica and Nordica, multipurpose icebreakers</segment>
		<segment id="3" parent="13" relname="span">chartered</segment>
		<segment id="4" parent="3" relname="purpose">to support Shell's drilling rigs near Alaska.</segment>
		<segment id="5" parent="20" relname="span">Around the same time period, a reporter for Fortune magazine spoke with Edward Itta, an Inupiat Eskimo leader and the former mayor of the North Slope Borough,</segment>
		<segment id="6" parent="18" relname="attribution">who expressed</segment>
		<segment id="7" parent="16" relname="span">that he was conflicted about Shell's plans in the Arctic,</segment>
		<segment id="8" parent="9" relname="attribution">as he was very concerned</segment>
		<segment id="9" parent="15" relname="span">that an oil spill could destroy the Inupiat Eskimo's hunting-and-fishing culture,</segment>
		<segment id="10" parent="17" relname="joint">but his borough also received major tax revenue from oil and gas production;</segment>
		<segment id="11" parent="17" relname="joint">additionally, further revenue from energy activity was considered crucial to the future of the living standard in Itta's community.</segment>
		<group id="21" type="multinuc" parent="22" relname="span"/>
		<group id="14" type="span" parent="21" relname="joint"/>
		<group id="13" type="span" parent="2" relname="elaboration"/>
		<group id="20" type="span" parent="21" relname="joint"/>
		<group id="19" type="span" parent="5" relname="elaboration"/>
		<group id="18" type="multinuc" parent="19" relname="span"/>
		<group id="16" type="span" parent="18" relname="adversative"/>
		<group id="15" type="span" parent="7" relname="explanation"/>
		<group id="17" type="multinuc" parent="18" relname="adversative"/>
		<group id="22" type="span"/>
	</body>
</rst>