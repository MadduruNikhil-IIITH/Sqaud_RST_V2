<rst>
	<header>
		<relations>
			<rel name="antithesis" type="multinuc" />
			<rel name="context" type="rst" />
			<rel name="elaboration" type="rst" />
			<rel name="joint" type="multinuc" />
			<rel name="mode" type="rst" />
		</relations>
	</header>
	<body>
		<segment id="1" parent="12" relname="joint">During the 14th century in the northeastern part of the state nomad tribes by the name of Jornado hunted bison along the Rio Grande;</segment>
		<segment id="2" parent="12" relname="joint">they left numerous rock paintings throughout the northeastern part of the state.</segment>
		<segment id="3" parent="4" relname="context">When the Spanish explorers reached this area</segment>
		<segment id="4" parent="13" relname="span">they found their descendants, Suma and Manso tribes.</segment>
		<segment id="5" parent="15" relname="span">In the southern part of the state, in a region</segment>
		<segment id="6" parent="5" relname="elaboration">known as Aridoamerica, Chichimeca people survived</segment>
		<segment id="7" parent="17" relname="joint">by hunting,</segment>
		<segment id="8" parent="16" relname="joint">gathering,</segment>
		<segment id="9" parent="16" relname="joint">and farming between AD 300 and 1300.</segment>
		<segment id="10" parent="18" relname="elaboration">The Chichimeca are the ancestors of the Tepehuan people.</segment>
		<group id="14" type="multinuc" parent="20" relname="joint"/>
		<group id="12" type="multinuc" parent="14" relname="joint"/>
		<group id="13" type="span" parent="14" relname="joint"/>
		<group id="19" type="span" parent="20" relname="joint"/>
		<group id="18" type="span" parent="19" relname="span"/>
		<group id="15" type="span" parent="18" relname="span"/>
		<group id="17" type="multinuc" parent="15" relname="mode"/>
		<group id="16" type="multinuc" parent="17" relname="joint"/>
		<group id="20" type="multinuc"/>
	</body>
</rst>