	</header>
	<body>
		<segment id="1" parent="19" relname="span">The Internet was extensively used</segment>
		<segment id="2" parent="18" relname="span">for passing information</segment>
		<segment id="3" parent="2" relname="purpose">to aid rescue and recovery efforts.</segment>
		<segment id="4" parent="20" relname="span">For example, the official news agency Xinhua set up an online rescue request center</segment>
		<segment id="5" parent="4" relname="purpose">in order to find the blind spots of disaster recovery.</segment>
		<segment id="6" parent="7" relname="attribution">After knowing</segment>
		<segment id="7" parent="21" relname="span">that rescue helicopters had trouble landing into the epicenter area in Wenchuan,</segment>
		<segment id="8" parent="23" relname="joint">a student proposed a landing spot online</segment>
		<segment id="9" parent="22" relname="span">and it was chosen as the first touchdown place for the helicopters</segment>
		<segment id="10" parent="9" relname="adversative">[not in citation given].</segment>
		<segment id="11" parent="25" relname="span">Volunteers also set up several websites</segment>
		<segment id="12" parent="11" relname="purpose">to help store contact information for victims and evacuees.</segment>
		<segment id="13" parent="28" relname="span">On May 31, a rescue helicopter</segment>
		<segment id="14" parent="13" relname="elaboration">carrying earthquake survivors and crew members</segment>
		<segment id="15" parent="29" relname="same-unit">crashed in fog and turbulence in Wenchuan county.</segment>
		<segment id="16" parent="29" relname="elaboration">No-one survived.</segment>
		<group id="19" type="span" parent="32" relname="span"/>
		<group id="18" type="span" parent="1" relname="purpose"/>
		<group id="31" type="multinuc" parent="19" relname="elaboration"/>
